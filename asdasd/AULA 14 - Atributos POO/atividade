class Livro():
    def __init__(self, nome, autor, ano):
        self.nome = nome
        self.autor = autor 
        self.ano = ano
        self.emprestado = False

    def emprestimo(self):
        if not self.emprestado:
            self.emprestado = True
            return ('livro pego')
    def devolver(self):
        if self.emprestado:
            self.emprestado = False
            return ('livro devolvido')
        
    def __str__(self):
        return f'{self.nome, self}{self.autor}{self.ano}'

nome, autor, ano = input('nome do livro: '), input(" autor do livro:"), input('ano do livro: ')
liv1 = Livro(nome, autor, ano)
liv1.emprestimo

print(liv1)


