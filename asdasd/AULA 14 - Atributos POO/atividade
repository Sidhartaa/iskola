class Produto:
    def __init__(self, nome, preco, quantidade):
        self._nome = nome
        self._preco = preco
        self._quantidade = quantidade

    @property
    def nome(self):
        return self._nome

    @property
    def preco(self):
        return self._preco

    @property
    def quantidade(self):
        return self._quantidade

    def desconto(self, percentual):
        descont = self._preco * percentual
        novo = self.preco - descont
        if self._preco >= 0:
            self._preco = novo 

p = Produto('hd', 1700, 1)
p.desconto(100)
print(p)
print(p.nome, p.preco )


