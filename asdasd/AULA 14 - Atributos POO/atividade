class Calculadora:

    @staticmethod
    def soma(a,b):
        return a + b 
    
    @staticmethod
    def subtrai(a,b):
        return a-b 
    @staticmethod
    def multiplica(a,b):
        return a*b 
    @staticmethod 
    def divisao(a,b):
        return a/b 
    

c = Calculadora()

print(c.soma(10, 15))
print(c.subtrai(10, 15))
print(c.divisao(10, 15))
print(c.multiplica(10, 15))
